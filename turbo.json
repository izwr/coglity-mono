{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "SESSION_SECRET",
    "AZURE_CLIENT_ID",
    "AZURE_CLIENT_SECRET",
    "AZURE_TENANT_ID",
    "AZURE_REDIRECT_URI",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_REDIRECT_URI",
    "CLIENT_URL",
    "OPENAI_API_KEY",
    "AZURE_OPENAI_REALTIME_ENDPOINT",
    "AZURE_OPENAI_REALTIME_DEPLOYMENT",
    "AZURE_OPENAI_REALTIME_API_VERSION",
    "EXECUTOR_URL",
    "EXECUTOR_WEBHOOK_SECRET",
    "BACKEND_INTERNAL_URL",
    "EXECUTOR_MAX_DURATION_MS",
    "EXECUTOR_MAX_TURNS",
    "EXECUTOR_SILENCE_MS",
    "AZURE_STORAGE_ACCOUNT",
    "AZURE_STORAGE_RECORDINGS_CONTAINER"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}

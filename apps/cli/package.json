{
  "name": "@coglity/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "coglity": "dist/index.js",
    "coglity-mcp": "dist/mcp/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsup",
    "compile": "tsup && bun build dist/index.js --compile --outfile dist/coglity",
    "compile:linux": "tsup && bun build dist/index.js --compile --target=bun-linux-x64 --outfile dist/coglity-linux",
    "compile:windows": "tsup && bun build dist/index.js --compile --target=bun-windows-x64 --outfile dist/coglity.exe",
    "start": "bun run src/index.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react": "^19.2.14",
    "clipanion": "^4.0.0-rc.4",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "mdast-util-to-string": "^4.0.0",
    "playwright": "^1.52.0",
    "react": "^19.2.4",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^3.25.11"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.2.1"
  }
}
